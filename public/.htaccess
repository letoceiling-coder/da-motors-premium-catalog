<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# Pretty webhook route for Telegram
RewriteRule ^telegram/webhook$ /api/telegram-webhook.php [L,QSA]

# Don't rewrite API requests
RewriteCond %{REQUEST_URI} ^/api/
RewriteRule . - [L]

# Don't rewrite if file exists
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule . - [L]

# Don't rewrite if directory exists
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule . - [L]

# SPA fallback - redirect all other requests to index.html
RewriteRule ^index\.html$ - [L]
RewriteRule . /index.html [L]
</IfModule>
